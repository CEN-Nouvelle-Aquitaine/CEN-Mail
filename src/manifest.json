{
  "manifest_version": 2,
  "name": "Mail-CEN",
  "version": "5.3.0",
  "description": "Outil de gestion mail du Conservatoire d'Espaces Naturels",
  "author": "Mail-CEN",
  "browser_specific_settings": {
    "gecko": {
      "id": "mail-cen@local",
      "strict_min_version": "115.0"
    }
  },
  "permissions": [
    "storage", "menus", "identity",
    "messagesRead", "messagesMove", "messagesImport", "messagesDelete",
    "messagesTags", "messagesTagsList", "messagesUpdate",
    "accountsRead", "accountsFolders",
    "addressBooks",
    "notifications",
    "tabs",
    "https://login.microsoftonline.com/*",
    "https://graph.microsoft.com/*",
    "https://dns.google/*"
  ],
  "background": { "page": "background.html" },
  "browser_action": {
    "default_title": "Mail-CEN",
    "default_popup": "popup/popup.html"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "64": "icons/icon-64.png"
  }
}
